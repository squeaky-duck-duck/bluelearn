{
  "name": "api",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "concurrently -n types,worker -c blue,yellow \"pnpm dev:types\" \"wrangler dev\"",
    "dev:types": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "build": "tsc -p tsconfig.build.json",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "types": "wrangler types",
    "docs:serve": "serve openapi -l 4000"
  },
  "dependencies": {
    "@bluelearn/schemas": "workspace:*",
    "@hono/zod-validator": "^0.8.0",
    "@supabase/supabase-js": "^2.105.4",
    "hono": "^4.12.18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@cloudflare/workers-types": "^4.20250508.0",
    "@eslint/js": "^10.0.1",
    "@types/ajv": "^1.0.4",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "serve": "^14.2.6",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.2.6",
    "wrangler": "^4.14.1"
  }
}
