# Prerequisites: Docker + Supabase CLI. Run `supabase start` first, then `supabase status` for values.
# Copy to .dev.vars for local Wrangler dev (`pnpm dev` in api/).
# Values come from `supabase status` (or `supabase status -o env`) after `supabase start`.
# For production, set these as Worker secrets in the Cloudflare dashboard (or via wrangler secret).

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Typesense variables
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=

# Frontend origin for CORS (Vite dev server)
APP_URL=http://localhost:3000

# Rate limiting: RATE_LIMITER is a Durable Object binding declared in
# wrangler.jsonc (not a secret, so not here). `wrangler dev` creates the
# DO locally and stores its state in .wrangler/state/v3/do/. No setup
# needed. Tests run without the binding and fall back to in-memory
# counters automatically.